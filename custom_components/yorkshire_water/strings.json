        "data_description": {
          "username": "Email address used to log in to the Yorkshire Water website.",
          "password": "Your Yorkshire Water password.",
          "account_number": "Your billing account reference number."
        },
        "description": "Enter your Yorkshire Water account credentials to connect to Home Assistant."
      }
    }
  },
  "entity": {
    "sensor": {
      "latest_consumption": {
        "name": "Latest daily usage"
      },
      "latest_cost": {
        "name": "Latest daily cost"
      },
      "yesterday_consumption": {
        "name": "Yesterday's usage"
      },
      "yesterday_cost": {
        "name": "Yesterday's cost"
      },
      "last_updated": {
        "name": "Last reading date"
      }
    }
  },
  "services": {
    "force_refresh": {
      "name": "Force refresh",
